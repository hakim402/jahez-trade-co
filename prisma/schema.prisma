// prisma/schema.prisma

generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

// ------------------------------------------------
// ENUMS
// ------------------------------------------------

enum UserRole {
  ADMIN
  CLIENT
}

enum RequestStatus {
  SUBMITTED
  IN_REVIEW
  QUOTED
  APPROVED
  REJECTED
  IN_PRODUCTION
  SHIPPED
  COMPLETED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

enum BookingType {
  MARKET
  FACTORY
  CUSTOM
}

enum BookingStatus {
  REQUESTED
  PROPOSED // Admin proposed time
  CONFIRMED // Client accepted
  REJECTED // Client rejected
  RESCHEDULED
  COMPLETED
  CANCELED
  NO_SHOW
}

enum MeetingProvider {
  ZOOM
  GOOGLE_MEET
  WHATSAPP
  MICROSOFT_TEAMS
  CUSTOM
}

enum SubscriptionItemStatus {
  ACTIVE
  CANCELED
  UPCOMING
  ENDED
  ABANDONED
  INCOMPLETE
  PAST_DUE
}

enum PaymentAttemptType {
  CHECKOUT
  RECURRING
}

enum PaymentAttemptStatus {
  PENDING
  PAID
  FAILED
}

// ------------------------------------------------
// USER MODEL
// ------------------------------------------------
model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  fullName  String?
  role      UserRole @default(CLIENT)
  phone     String?
  avatarUrl String?

  isActive  Boolean @default(true)
  isDeleted Boolean @default(false)

  // -------------------------
  // Product Requests
  // -------------------------
  requests ProductRequest[]

  // -------------------------
  // Quotes
  // -------------------------
  quotesCreated Quote[] @relation("AdminQuotes")

  // -------------------------
  // Video Bookings
  // -------------------------
  clientBookings  VideoBooking[] @relation("ClientBookings")
  handledBookings VideoBooking[] @relation("AdminBookings")

  // -------------------------
  // Booking Status History
  // -------------------------
  bookingStatusChanges BookingStatusHistory[]

  // -------------------------
  // Request Status History
  // -------------------------
  requestStatusChanges RequestStatusHistory[]

  // -------------------------
  // Quote Status History
  // -------------------------
  quoteStatusChanges QuoteStatusHistory[]

  // -------------------------
  // Files
  // -------------------------
  uploadedFiles File[]

  // -------------------------
  // Notifications
  // -------------------------
  notifications Notification[]

  // -------------------------
  // Audit Logs
  // -------------------------
  adminAuditLogs AuditLog[] @relation("audit_admin")

  // -------------------------
  // Chat
  // -------------------------
  chatSessions ChatSession[]

  // -------------------------
  // Trending
  // -------------------------
  trendingProductRequests TrendingProductRequest[]
  addedProducts           TrendingProduct[]        @relation("AdminAddedProducts") // FIX: back-relation for addedBy

  // -------------------------
  // Consulting
  // -------------------------
  consultingRequests ConsultingRequest[]

  // -------------------------
  // Subscription (DO NOT TOUCH)
  // -------------------------
  subscription Subscription?

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  availabilitySlots AvailabilitySlot[]

  @@index([role])
  @@index([isDeleted])
}

// ------------------------------------------------
// SUBSCRIPTION MODEL (Top-level container)
// ------------------------------------------------
model Subscription {
  id                  String @id @default(cuid())
  clerkSubscriptionId String @unique

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  items           SubscriptionItem[]
  paymentAttempts PaymentAttempt[]

  lastSyncPayload Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId])
  @@index([clerkSubscriptionId])
}

// ------------------------------------------------
// SUBSCRIPTION ITEM MODEL
// ------------------------------------------------
model SubscriptionItem {
  id          String @id @default(cuid())
  clerkItemId String @unique

  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  planId String?
  plan   Plan?   @relation(fields: [planId], references: [id])

  status SubscriptionItemStatus

  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?

  isDefaultPlan Boolean @default(false)

  trialEndsAt DateTime?

  paymentAttempts PaymentAttempt[]

  lastSyncPayload Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clerkItemId])
  @@index([status])
}

// ------------------------------------------------
// PAYMENT ATTEMPT MODEL
// ------------------------------------------------
model PaymentAttempt {
  id                    String @id @default(cuid())
  clerkPaymentAttemptId String @unique

  type   PaymentAttemptType
  status PaymentAttemptStatus

  subscriptionItemId String?
  subscriptionItem   SubscriptionItem? @relation(fields: [subscriptionItemId], references: [id])

  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])

  amount   Decimal? @db.Decimal(10, 2)
  currency String   @default("USD")

  occurredAt DateTime

  payload Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clerkPaymentAttemptId])
  @@index([status])
}

// ------------------------------------------------
// PLAN MODEL
// ------------------------------------------------
model Plan {
  id              String  @id @default(cuid())
  clerkPlanId     String  @unique
  name            String
  amount          Decimal @db.Decimal(10, 2)
  currency        String  @default("USD")
  interval        String?
  intervalCount   Int?
  trialPeriodDays Int?
  isDefault       Boolean @default(false)

  subscriptionItems SubscriptionItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clerkPlanId])
}

// ------------------------------------------------
// VIDEO BOOKING
// ------------------------------------------------
model VideoBooking {
  id String @id @default(cuid())

  clientId String
  client   User   @relation("ClientBookings", fields: [clientId], references: [id])

  type            BookingType
  requestNotes    String?     @db.Text
  durationMinutes Int         @default(30)

  status BookingStatus @default(REQUESTED)

  handledById String?
  handledBy   User?   @relation("AdminBookings", fields: [handledById], references: [id])

  scheduledAt     DateTime?
  meetingProvider MeetingProvider?
  meetingLink     String?
  meetingPassword String?

  clientConfirmedAt DateTime?

  transcriptUrl String?
  aiSummary     String? @db.Text

  slotId String?           @unique
  slot   AvailabilitySlot? @relation(fields: [slotId], references: [id])

  isDeleted Boolean @default(false)

  statusHistory BookingStatusHistory[]
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([handledById])
  @@index([status])
  @@index([scheduledAt])
}

// ------------------------------------------------
// VIDEO BOOKING STATUS HISTORY
// ------------------------------------------------
model BookingStatusHistory {
  id String @id @default(cuid())

  bookingId String
  booking   VideoBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  oldStatus BookingStatus
  newStatus BookingStatus

  changedById String
  changedBy   User   @relation(fields: [changedById], references: [id])

  changedAt DateTime @default(now())

  @@index([bookingId])
}

// ------------------------------------------------
// AVAILABILITY SLOT
// ------------------------------------------------
model AvailabilitySlot {
  id String @id @default(cuid())

  startTime       DateTime
  endTime         DateTime
  durationMinutes Int

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  isBooked Boolean @default(false)
  isActive Boolean @default(true)

  booking VideoBooking?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startTime])
  @@index([createdById])
  @@index([isBooked])
}

// ------------------------------------------------
// PRODUCT REQUEST MODEL
// ------------------------------------------------
model ProductRequest {
  id String @id @default(cuid())

  clientId String
  client   User   @relation(fields: [clientId], references: [id])

  productLink     String?
  description     String? @db.Text
  quantity        Int
  shippingCountry String
  customNotes     String? @db.Text

  status   RequestStatus @default(SUBMITTED)
  priority Int           @default(0)

  acceptedQuoteId String? @unique
  acceptedQuote   Quote?  @relation("AcceptedQuote", fields: [acceptedQuoteId], references: [id])

  aiParsedData     Json?
  aiEstimatedPrice Decimal? @db.Decimal(10, 2)
  aiConfidence     Float?

  isDeleted Boolean @default(false)

  files                   File[]
  quotes                  Quote[]
  statusHistory           RequestStatusHistory[]
  aiSuggestions           AISuggestion[]
  notifications           Notification[]
  trendingProductRequests TrendingProductRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([createdAt])
  @@index([isDeleted])
}

// ------------------------------------------------
// PRODUCT REQUEST STATUS HISTORY
// ------------------------------------------------
model RequestStatusHistory {
  id String @id @default(cuid())

  requestId String
  request   ProductRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  oldStatus RequestStatus
  newStatus RequestStatus

  changedById String
  changedBy   User   @relation(fields: [changedById], references: [id])

  changedAt DateTime @default(now())

  @@index([requestId])
}

// ------------------------------------------------
// QUOTE MODEL
// ------------------------------------------------
model Quote {
  id String @id @default(cuid())

  requestId String
  request   ProductRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("AdminQuotes", fields: [createdById], references: [id])

  price    Decimal @db.Decimal(12, 2)
  currency String  @default("USD")

  status QuoteStatus @default(DRAFT)

  validUntil DateTime?
  revision   Int       @default(1)

  adminNotes String? @db.Text

  isDeleted Boolean @default(false)

  acceptedFor ProductRequest? @relation("AcceptedQuote")

  files         File[]
  statusHistory QuoteStatusHistory[]
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([requestId])
  @@index([createdById])
  @@index([status])
  @@index([isDeleted])
}

// ------------------------------------------------
// QUOTE STATUS HISTORY
// ------------------------------------------------
model QuoteStatusHistory {
  id String @id @default(cuid())

  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  oldStatus QuoteStatus
  newStatus QuoteStatus

  changedById String
  changedBy   User   @relation(fields: [changedById], references: [id])

  changedAt DateTime @default(now())

  @@index([quoteId])
}

// ------------------------------------------------
// FILE UPLOAD MODEL
// ------------------------------------------------
model File {
  id String @id @default(cuid())

  url      String
  fileType String
  fileName String?
  fileSize Int?

  requestId String?
  quoteId   String?

  request ProductRequest? @relation(fields: [requestId], references: [id], onDelete: Cascade)
  quote   Quote?          @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  uploadedById String?
  uploadedBy   User?   @relation(fields: [uploadedById], references: [id])

  createdAt DateTime @default(now())

  @@index([requestId])
  @@index([quoteId])
}

// ------------------------------------------------
// AI SUGGESTION MODEL
// ------------------------------------------------
model AISuggestion {
  id String @id @default(cuid())

  requestId String
  request   ProductRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  estimatedPrice Decimal @db.Decimal(10, 2)
  currency       String  @default("USD")
  confidence     Float?

  suggestedSupplierIds Json?

  createdAt DateTime @default(now())

  @@index([requestId])
}

// ------------------------------------------------
// AUDIT LOG MODEL
// ------------------------------------------------
model AuditLog {
  id        String   @id @default(cuid())
  adminId   String
  admin     User     @relation("audit_admin", fields: [adminId], references: [id])
  action    String
  entity    String
  entityId  String?
  changes   Json?
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([entity])
  @@index([createdAt])
}

// ------------------------------------------------
// NOTIFICATION MODEL
// ------------------------------------------------
model Notification {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  title   String
  message String @db.Text

  isRead Boolean @default(false)
  type   String

  metadata Json?

  bookingId String?
  booking   VideoBooking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  requestId String?
  request   ProductRequest? @relation(fields: [requestId], references: [id], onDelete: Cascade)

  quoteId String?
  quote   Quote?  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
}

// ------------------------------------------------
// CHAT SESSION MODEL
// ------------------------------------------------
model ChatSession {
  id        String    @id @default(cuid())
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  startedAt DateTime  @default(now())
  endedAt   DateTime?

  messages ChatMessage[]

  @@index([userId])
  @@index([startedAt])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String // "user" or "assistant"
  content   String      @db.Text
  createdAt DateTime    @default(now())

  @@index([sessionId])
}


// ============================================================
// NEW MODELS
// ============================================================

// ------------------------------------------------
// TRENDING PRODUCT MODEL
// ------------------------------------------------
model TrendingProduct {
  id String @id @default(cuid())

  // Core Info (bilingual)
  name          String
  nameAr        String?
  description   String? @db.Text
  descriptionAr String? @db.Text
  shortDesc     String?
  shortDescAr   String?

  // Pricing & Origin
  estimatedPrice Decimal? @db.Decimal(10, 2)
  currency       String   @default("USD")
  sourceCountry  String? // e.g. "CN", "US"
  sourceUrl      String? // Link to original listing (Alibaba, 1688, etc.)
  supplier       String?

  // Categorization
  category   String?
  categoryAr String?
  tags       String[] // e.g. ["electronics", "summer", "new"]

  // Trend Metadata
  trendScore    Int      @default(0) // Higher = more trending
  viewCount     Int      @default(0)
  inquiryCount  Int      @default(0) // How many requests linked
  isFeatured    Boolean  @default(false)
  featuredUntil DateTime?

  // Images
  images TrendingProductImage[]

  // FIX: proper FK relation to User (admin who added this product)
  addedById String?
  addedBy   User?   @relation("AdminAddedProducts", fields: [addedById], references: [id], onDelete: SetNull)

  isActive  Boolean @default(true)
  isDeleted Boolean @default(false)

  relatedRequests TrendingProductRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, isDeleted])
  @@index([trendScore])
  @@index([isFeatured])
  @@index([category])
  @@index([createdAt])
  @@index([addedById])
}

// ------------------------------------------------
// TRENDING PRODUCT IMAGE
// ------------------------------------------------
model TrendingProductImage {
  id        String          @id @default(cuid())
  productId String
  product   TrendingProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  altText   String?
  isPrimary Boolean         @default(false)
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())

  @@index([productId])
}

// ------------------------------------------------
// TRENDING PRODUCT REQUEST (junction)
// ------------------------------------------------
model TrendingProductRequest {
  id        String          @id @default(cuid())
  productId String
  product   TrendingProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  requestId String?
  request   ProductRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)
  userId    String?
  user      User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime        @default(now())

  @@index([productId])
  @@index([userId])
  @@index([requestId])
}

// ------------------------------------------------
// WHATSAPP MESSAGE LOG
// (loose FKs intentional — log table survives cascading deletes)
// ------------------------------------------------
model WhatsAppLog {
  id          String    @id @default(cuid())
  to          String // recipient: +966xxxxxxxxx
  message     String    @db.Text
  templateKey String? // e.g. "request_submitted", "quote_ready"
  status      String    @default("pending") // pending | sent | failed
  provider    String    @default("twilio")
  externalId  String? // Twilio MessageSid
  userId      String? // intentionally loose — log survives user delete
  requestId   String? // intentionally loose
  quoteId     String? // intentionally loose
  bookingId   String? // intentionally loose
  error       String?   @db.Text
  sentAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([to])
  @@index([status])
  @@index([userId])
  @@index([requestId])
}

// ------------------------------------------------
// SHIPPING ESTIMATE LOG
// (loose userId intentional — log table)
// ------------------------------------------------
model ShippingEstimate {
  id                 String   @id @default(cuid())
  userId             String? // intentionally loose — log survives user delete
  originCountry      String
  destinationCountry String
  weightKg           Decimal  @db.Decimal(10, 3)
  volumeCbm          Decimal? @db.Decimal(10, 4)
  freightType        String // "air" | "sea"
  estimatedCost      Decimal  @db.Decimal(10, 2)
  currency           String   @default("USD")
  transitDays        Int?
  createdAt          DateTime @default(now())

  @@index([userId])
  @@index([freightType])
}

// ------------------------------------------------
// BUSINESS CONSULTING REQUEST
// ------------------------------------------------
model ConsultingRequest {
  id          String   @id @default(cuid())
  // FIX: proper FK relation to User
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  fullName    String
  email       String
  phone       String?
  company     String?
  topic       String // "sourcing" | "import" | "logistics" | "market_entry" | "supplier" | "other"
  description String   @db.Text
  budget      String? // e.g. "$5k-$10k"
  status      String   @default("NEW") // NEW | IN_REVIEW | SCHEDULED | CLOSED
  adminNotes  String?  @db.Text
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([userId])
}
