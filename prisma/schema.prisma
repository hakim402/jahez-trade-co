// prisma/schema.prisma

generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

// ------------------------------------------------
// ENUMS
// ------------------------------------------------

enum UserRole {
  ADMIN
  CLIENT
}

enum RequestStatus {
  SUBMITTED
  IN_REVIEW
  QUOTED
  APPROVED
  REJECTED
  IN_PRODUCTION
  SHIPPED
  COMPLETED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

enum BookingType {
  MARKET
  FACTORY
  CUSTOM
}

enum BookingStatus {
  REQUESTED
  PROPOSED
  CONFIRMED
  REJECTED
  RESCHEDULED
  COMPLETED
  CANCELED
  NO_SHOW
}

enum MeetingProvider {
  ZOOM
  GOOGLE_MEET
  WHATSAPP
  MICROSOFT_TEAMS
  CUSTOM
}

enum SubscriptionItemStatus {
  ACTIVE
  CANCELED
  UPCOMING
  ENDED
  ABANDONED
  INCOMPLETE
  PAST_DUE
}

enum PaymentAttemptType {
  CHECKOUT
  RECURRING
}

enum PaymentAttemptStatus {
  PENDING
  PAID
  FAILED
}

enum ConsultingServiceTopic {
  sourcing
  import
  logistics
  market_entry
  supplier
  other
}

enum ConsultingDeliveryFormat {
  video_call
  written_report
  on_site
  hybrid
  async
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ReactionType {
  LIKE
  DISLIKE
}

enum FreightType {
  AIR
  SEA
  LAND
  EXPRESS
}

// ------------------------------------------------
// SHIPPING & TRACKING ENUMS
// ------------------------------------------------
enum ShipmentStatus {
  BOOKED
  PICKED_UP
  IN_TRANSIT
  ARRIVED_ORIGIN_PORT
  CUSTOMS_ORIGIN
  DEPARTED
  ARRIVED_DESTINATION
  CUSTOMS_DESTINATION
  OUT_FOR_DELIVERY
  DELIVERED
  DELAYED
  EXCEPTION
  CANCELED
  RETURNED
}

enum TrackingSource {
  MANUAL
  API_17TRACK
  API_SHIP24
  API_AFTERSHIP
}

enum EventSource {
  MANUAL
  API
  SYSTEM
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELED
}

// ------------------------------------------------
// USER MODEL
// ------------------------------------------------
model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  fullName  String?
  role      UserRole @default(CLIENT)
  phone     String?
  avatarUrl String?

  isActive  Boolean @default(true)
  isDeleted Boolean @default(false)

  requests                  ProductRequest[]
  quotesCreated             Quote[]                    @relation("AdminQuotes")
  clientBookings            VideoBooking[]             @relation("ClientBookings")
  handledBookings           VideoBooking[]             @relation("AdminBookings")
  bookingStatusChanges      BookingStatusHistory[]
  requestStatusChanges      RequestStatusHistory[]
  quoteStatusChanges        QuoteStatusHistory[]
  uploadedFiles             File[]
  notifications             Notification[]
  adminAuditLogs            AuditLog[]                 @relation("audit_admin")
  chatSessions              ChatSession[]
  trendingProductRequests   TrendingProductRequest[]
  addedProducts             TrendingProduct[]          @relation("AdminAddedProducts")
  consultingRequests        ConsultingRequest[]
  subscription              Subscription?
  availabilitySlots         AvailabilitySlot[]
  addedServices             ConsultingService[]        @relation("AdminAddedServices")
  consultingServiceRequests ConsultingServiceRequest[]
  blogPosts                 Post[]
  comments                  Comment[]
  postReactions             PostReaction[]
  commentReactions          CommentReaction[]
  isEmployee                Boolean                    @default(false)
  employeeProfile           EmployeeProfile?
  shippingEstimates         ShippingEstimate[]

  // ── Shipping & tracking system ──────────────────
  shipments                  Shipment[]         @relation("ClientShipments")
  createdShipments           Shipment[]         @relation("AdminCreatedShipments")
  shipmentEventsAdded        ShipmentEvent[]
  guestClientsCreated        GuestClient[]      @relation("AdminCreatedGuestClients")
  invoices                   Invoice[]          @relation("ClientInvoices")
  invoicesCreated            Invoice[]          @relation("AdminCreatedInvoices")
  integrationSettingsUpdated IntegrationSetting[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([isDeleted])
}

// ------------------------------------------------
// EMPLOYEE PROFILE MODEL
// ------------------------------------------------
model EmployeeProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // –– Core (bilingual) ––––––––––––––––
  positionEn String? // "Sourcing Manager"
  positionAr String? // "مدير التوريد"
  bioEn      String? @db.Text
  bioAr      String? @db.Text
  shortBioEn String?
  shortBioAr String?

  // –– Slug for detail pages –––––––––
  slug String? @unique // e.g. "john-doe"

  // –– Visibility –––––––––––––––––––––
  status       String @default("DRAFT") // DRAFT | PUBLISHED
  displayOrder Int    @default(0)

  // –– Media ––––––––––––––––––––––––––
  photoUrl   String?
  photoAltEn String?
  photoAltAr String?

  // –– Social links (dedicated strings) ––
  facebookUrl  String?
  instagramUrl String?
  twitterUrl   String? // X / Twitter
  linkedinUrl  String?
  youtubeUrl   String?
  tiktokUrl    String?
  snapchatUrl  String?
  otherLinks   Json? // [{ platform, url }] catch-all

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status, displayOrder])
}

// ------------------------------------------------
// SUBSCRIPTION MODEL
// ------------------------------------------------
model Subscription {
  id                  String @id @default(cuid())
  clerkSubscriptionId String @unique

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  items           SubscriptionItem[]
  paymentAttempts PaymentAttempt[]
  lastSyncPayload Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId])
  @@index([clerkSubscriptionId])
}

// ------------------------------------------------
// SUBSCRIPTION ITEM MODEL
// ------------------------------------------------
model SubscriptionItem {
  id          String @id @default(cuid())
  clerkItemId String @unique

  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  planId String?
  plan   Plan?   @relation(fields: [planId], references: [id])

  status             SubscriptionItemStatus
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  isDefaultPlan      Boolean                @default(false)
  trialEndsAt        DateTime?
  paymentAttempts    PaymentAttempt[]
  lastSyncPayload    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clerkItemId])
  @@index([status])
}

// ------------------------------------------------
// PAYMENT ATTEMPT MODEL
// ------------------------------------------------
model PaymentAttempt {
  id                    String @id @default(cuid())
  clerkPaymentAttemptId String @unique

  type   PaymentAttemptType
  status PaymentAttemptStatus

  subscriptionItemId String?
  subscriptionItem   SubscriptionItem? @relation(fields: [subscriptionItemId], references: [id])

  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])

  amount     Decimal? @db.Decimal(10, 2)
  currency   String   @default("USD")
  occurredAt DateTime
  payload    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clerkPaymentAttemptId])
  @@index([status])
}

// ------------------------------------------------
// PLAN MODEL
// ------------------------------------------------
model Plan {
  id              String  @id @default(cuid())
  clerkPlanId     String  @unique
  name            String
  amount          Decimal @db.Decimal(10, 2)
  currency        String  @default("USD")
  interval        String?
  intervalCount   Int?
  trialPeriodDays Int?
  isDefault       Boolean @default(false)

  subscriptionItems SubscriptionItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clerkPlanId])
}

// ------------------------------------------------
// VIDEO BOOKING
// ------------------------------------------------
model VideoBooking {
  id String @id @default(cuid())

  clientId String
  client   User   @relation("ClientBookings", fields: [clientId], references: [id])

  type            BookingType
  requestNotes    String?       @db.Text
  durationMinutes Int           @default(30)
  status          BookingStatus @default(REQUESTED)

  handledById String?
  handledBy   User?   @relation("AdminBookings", fields: [handledById], references: [id])

  scheduledAt       DateTime?
  meetingProvider   MeetingProvider?
  meetingLink       String?
  meetingPassword   String?
  clientConfirmedAt DateTime?
  transcriptUrl     String?
  aiSummary         String?          @db.Text

  slotId String?           @unique
  slot   AvailabilitySlot? @relation(fields: [slotId], references: [id])

  isDeleted Boolean @default(false)

  statusHistory BookingStatusHistory[]
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([handledById])
  @@index([status])
  @@index([scheduledAt])
}

// ------------------------------------------------
// VIDEO BOOKING STATUS HISTORY
// ------------------------------------------------
model BookingStatusHistory {
  id String @id @default(cuid())

  bookingId String
  booking   VideoBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  oldStatus   BookingStatus
  newStatus   BookingStatus
  changedById String
  changedBy   User          @relation(fields: [changedById], references: [id])
  changedAt   DateTime      @default(now())

  @@index([bookingId])
}

// ------------------------------------------------
// AVAILABILITY SLOT
// ------------------------------------------------
model AvailabilitySlot {
  id String @id @default(cuid())

  startTime       DateTime
  endTime         DateTime
  durationMinutes Int

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  isBooked Boolean       @default(false)
  isActive Boolean       @default(true)
  booking  VideoBooking?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startTime])
  @@index([createdById])
  @@index([isBooked])
}

// ------------------------------------------------
// PRODUCT REQUEST MODELS
// ------------------------------------------------
model ProductRequest {
  id String @id @default(cuid())

  clientId String
  client   User   @relation(fields: [clientId], references: [id])

  productLink     String?
  description     String? @db.Text
  quantity        Int
  shippingCountry String
  customNotes     String? @db.Text

  status          RequestStatus @default(SUBMITTED)
  priority        Int           @default(0)
  acceptedQuoteId String?       @unique
  acceptedQuote   Quote?        @relation("AcceptedQuote", fields: [acceptedQuoteId], references: [id])

  aiParsedData     Json?
  aiEstimatedPrice Decimal? @db.Decimal(10, 2)
  aiConfidence     Float?
  isDeleted        Boolean  @default(false)

  files                   File[]
  quotes                  Quote[]
  statusHistory           RequestStatusHistory[]
  aiSuggestions           AISuggestion[]
  notifications           Notification[]
  trendingProductRequests TrendingProductRequest[]
  shipments               Shipment[]
  invoices                Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([createdAt])
  @@index([isDeleted])
}

model RequestStatusHistory {
  id String @id @default(cuid())

  requestId String
  request   ProductRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  oldStatus   RequestStatus
  newStatus   RequestStatus
  changedById String
  changedBy   User          @relation(fields: [changedById], references: [id])
  changedAt   DateTime      @default(now())

  @@index([requestId])
}

model Quote {
  id String @id @default(cuid())

  requestId String
  request   ProductRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("AdminQuotes", fields: [createdById], references: [id])

  price      Decimal     @db.Decimal(12, 2)
  currency   String      @default("USD")
  status     QuoteStatus @default(DRAFT)
  validUntil DateTime?
  revision   Int         @default(1)
  adminNotes String?     @db.Text
  isDeleted  Boolean     @default(false)

  acceptedFor   ProductRequest?      @relation("AcceptedQuote")
  files         File[]
  statusHistory QuoteStatusHistory[]
  notifications Notification[]
  shipments     Shipment[]
  invoices      Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([requestId])
  @@index([createdById])
  @@index([status])
  @@index([isDeleted])
}

model QuoteStatusHistory {
  id String @id @default(cuid())

  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  oldStatus   QuoteStatus
  newStatus   QuoteStatus
  changedById String
  changedBy   User        @relation(fields: [changedById], references: [id])
  changedAt   DateTime    @default(now())

  @@index([quoteId])
}

model File {
  id String @id @default(cuid())

  url      String
  fileType String
  fileName String?
  fileSize Int?

  requestId String?
  quoteId   String?
  request   ProductRequest? @relation(fields: [requestId], references: [id], onDelete: Cascade)
  quote     Quote?          @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())

  @@index([requestId])
  @@index([quoteId])
}

model AISuggestion {
  id String @id @default(cuid())

  requestId String
  request   ProductRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  estimatedPrice       Decimal  @db.Decimal(10, 2)
  currency             String   @default("USD")
  confidence           Float?
  suggestedSupplierIds Json?
  createdAt            DateTime @default(now())

  @@index([requestId])
}

// ------------------------------------------------
// SHIPPING ESTIMATIONS
// ------------------------------------------------
model ShippingRate {
  id String @id @default(cuid())

  originCountry      String
  destinationCountry String
  freightType        String

  calculationMode String  @default("PER_KG")
  goodsType       String?

  baseFee    Decimal  @default(0) @db.Decimal(10, 2)
  ratePerKg  Decimal? @db.Decimal(10, 2)
  ratePerCbm Decimal? @db.Decimal(10, 2)
  minCharge  Decimal  @default(0) @db.Decimal(10, 2)

  transitDaysMin Int?
  transitDaysMax Int?

  currency String  @default("USD")
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([originCountry, destinationCountry])
  @@index([freightType])
  @@index([calculationMode])
  @@index([isActive])
}

model ShippingEstimate {
  id String @id @default(cuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  originCountry      String
  destinationCountry String

  freightType     String
  calculationMode String  @default("PER_KG")
  goodsType       String?

  weightKg Decimal? @db.Decimal(10, 3)
  lengthCm Decimal? @db.Decimal(10, 2)
  widthCm  Decimal? @db.Decimal(10, 2)
  heightCm Decimal? @db.Decimal(10, 2)
  quantity Int      @default(1)

  volumeCbm          Decimal? @db.Decimal(10, 4)
  chargeableWeightKg Decimal? @db.Decimal(10, 3)

  baseFee    Decimal  @default(0) @db.Decimal(10, 2)
  ratePerKg  Decimal? @db.Decimal(10, 2)
  ratePerCbm Decimal? @db.Decimal(10, 2)

  estimatedCost Decimal @db.Decimal(10, 2)
  currency      String  @default("USD")
  transitDays   Int?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([userId])
  @@index([freightType])
  @@index([calculationMode])
  @@index([originCountry, destinationCountry])
  @@index([createdAt])
}

// ============================================================
// TRENDING PRODUCTS
// ============================================================
model TrendingProduct {
  id String @id @default(cuid())

  name          String
  nameAr        String?
  slug          String?  @unique
  slugAr        String? @unique
  description   String? @db.Text
  descriptionAr String? @db.Text
  shortDesc     String?
  shortDescAr   String?

  estimatedPrice Decimal? @db.Decimal(10, 2)
  currency       String   @default("USD")
  sourceCountry  String?
  sourceUrl      String?
  supplier       String?

  category      String?
  categoryAr    String?
  tags          String[]
  trendScore    Int       @default(0)
  viewCount     Int       @default(0)
  inquiryCount  Int       @default(0)
  isFeatured    Boolean   @default(false)
  featuredUntil DateTime?

  images    TrendingProductImage[]
  addedById String?
  addedBy   User?                  @relation("AdminAddedProducts", fields: [addedById], references: [id], onDelete: SetNull)

  isActive  Boolean @default(true)
  isDeleted Boolean @default(false)

  relatedRequests TrendingProductRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, isDeleted])
  @@index([trendScore])
  @@index([isFeatured])
  @@index([category])
  @@index([createdAt])
  @@index([addedById])
  @@index([slug])
  @@index([slugAr])
}

model TrendingProductImage {
  id        String          @id @default(cuid())
  productId String
  product   TrendingProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  altText   String?
  isPrimary Boolean         @default(false)
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())

  @@index([productId])
}

model TrendingProductRequest {
  id        String          @id @default(cuid())
  productId String
  product   TrendingProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  requestId String?
  request   ProductRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)
  userId    String?
  user      User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime        @default(now())

  @@index([productId])
  @@index([userId])
  @@index([requestId])
}

// ============================================================
// CONSULTING MODELS 
// ============================================================
model ConsultingRequest {
  id              String                     @id @default(cuid())
  userId          String?
  user            User?                      @relation(fields: [userId], references: [id], onDelete: SetNull)
  fullName        String
  email           String
  phone           String?
  company         String?
  topic           String
  description     String                     @db.Text
  budget          String?
  status          String                     @default("NEW")
  adminNotes      String?                    @db.Text
  isDeleted       Boolean                    @default(false)
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  serviceRequests ConsultingServiceRequest[]

  @@index([status])
  @@index([userId])
}

model ConsultingService {
  id String @id @default(cuid())

  // ── Bilingual content ──────────────────────────
  title         String // EN title
  titleAr       String? // AR title
  description   String  @db.Text // EN full description
  descriptionAr String? @db.Text // AR full description
  shortDesc     String? // EN one-liner shown on card
  shortDescAr   String? // AR one-liner shown on card

  // ── Topic ──────────────────────────────────────
  topic ConsultingServiceTopic @default(other)

  // ── Categorisation ─────────────────────────────
  category   String?
  categoryAr String?
  tags       String[] @default([])

  // ── Pricing hint ─
  priceFrom     Decimal? @db.Decimal(10, 2)
  priceCurrency String   @default("USD")

  // ── Duration hint ──────────────────────────────
  duration   String?
  durationAr String?

  // ── Delivery format ────────────────────────────
  deliveryFormat ConsultingDeliveryFormat?

  // ── What's included (bullet points) ───────────
  includesEn String[] @default([])
  includesAr String[] @default([])

  // ── Popularity / trend metadata ────────────────
  viewCount     Int       @default(0)
  requestCount  Int       @default(0)
  isFeatured    Boolean   @default(false)
  featuredUntil DateTime?
  sortOrder     Int       @default(0)

  // ── Images ─────────────────────────────────────
  images ConsultingServiceImage[]

  // ── Admin who created this service ─────────────
  addedById String?
  addedBy   User?   @relation("AdminAddedServices", fields: [addedById], references: [id], onDelete: SetNull)

  // ── Visibility ─────────────────────────────────
  isActive  Boolean @default(true)
  isDeleted Boolean @default(false)

  // ── Back-relations ─────────────────────────────
  serviceRequests ConsultingServiceRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, isDeleted])
  @@index([topic])
  @@index([isFeatured])
  @@index([sortOrder])
  @@index([requestCount])
  @@index([addedById])
  @@index([createdAt])
}

model ConsultingServiceImage {
  id        String            @id @default(cuid())
  serviceId String
  service   ConsultingService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  url       String
  altText   String?
  isPrimary Boolean           @default(false)
  sortOrder Int               @default(0)
  createdAt DateTime          @default(now())

  @@index([serviceId])
}

model ConsultingServiceRequest {
  id String @id @default(cuid())

  serviceId String
  service   ConsultingService @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  requestId String?
  request   ConsultingRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([serviceId])
  @@index([requestId])
  @@index([userId])
}

// ------------------------------------------------
// BLOGS POST
// ------------------------------------------------
model PostCategory {
  id     String  @id @default(cuid())
  slug   String  @unique // language‑neutral (e.g. "web-dev")
  nameEn String
  nameAr String?
  descEn String? @db.Text
  descAr String? @db.Text

  parentId String?
  parent   PostCategory?  @relation("CatHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children PostCategory[] @relation("CatHierarchy")

  posts Post[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

model PostTag {
  id     String  @id @default(cuid())
  slug   String  @unique
  nameEn String
  nameAr String?

  posts PostTagOnPost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id String @id @default(cuid())

  // ── Content ─────────────────────────────────────
  titleEn   String
  titleAr   String?
  slugEn    String  @unique
  slugAr    String? @unique
  excerptEn String? @db.Text
  excerptAr String? @db.Text
  contentEn String  @db.Text // rich HTML / JSON
  contentAr String? @db.Text

  // ── Status & visibility ─────────────────────────
  status      PostStatus @default(DRAFT)
  publishedAt DateTime?
  isDeleted   Boolean    @default(false)

  // ── Author (must be an ADMIN in your app) ───────
  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  // ── Category ────────────────────────────────────
  categoryId String?
  category   PostCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // ── SEO (bilingual) ─────────────────────────────
  metaTitleEn       String?
  metaTitleAr       String?
  metaDescriptionEn String? @db.Text
  metaDescriptionAr String? @db.Text
  ogImageUrl        String? // shared or overridable
  ogImageAltEn      String?
  ogImageAltAr      String?
  twitterCard       String? @default("summary_large_image")
  canonicalUrl      String?

  // ── Media ───────────────────────────────────────
  images PostImage[]
  videos PostVideoEmbed[]

  // ── Taxonomy ────────────────────────────────────
  tags PostTagOnPost[]

  // ── User interactions ───────────────────────────
  comments  Comment[]
  reactions PostReaction[]
  viewCount Int            @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, publishedAt, isDeleted])
  @@index([authorId])
  @@index([categoryId])
  @@index([slugEn])
  @@index([slugAr])
}

model PostImage {
  id     String @id @default(cuid())
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  url     String // required, no fallback to File
  altText String?

  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([postId, sortOrder])
}

model PostVideoEmbed {
  id     String @id @default(cuid())
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  url       String
  sortOrder Int    @default(0)

  createdAt DateTime @default(now())

  @@index([postId, sortOrder])
}

model PostTagOnPost {
  postId String
  tagId  String
  post   Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    PostTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

model Comment {
  id     String @id @default(cuid())
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  content String @db.Text

  // Nested replies
  parentId String?
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  // Reactions on this comment
  reactions CommentReaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId, createdAt])
  @@index([authorId])
  @@index([parentId])
}

model PostReaction {
  id     String @id @default(cuid())
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  type ReactionType

  createdAt DateTime @default(now())

  @@unique([postId, userId]) // one reaction per user per post
  @@index([postId, type])
}

model CommentReaction {
  id        String  @id @default(cuid())
  commentId String
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  type ReactionType

  createdAt DateTime @default(now())

  @@unique([commentId, userId]) // one reaction per user per comment
  @@index([commentId, type])
}

model GoogleAd {
  id String @id @default(cuid())

  // Placement identifier (e.g. "post-sidebar", "in-content-1", "site-header")
  placement String @unique

  // Ad unit codes per language (AdSense publisher ID + slot ID)
  adCodeEn String? // English ad code
  adCodeAr String? // Arabic ad code

  // Optional: ad type (display, in‑article, etc.)
  adType String? @default("display")

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([placement, isActive])
}

// ============================================================
// WHATSAPP LOGS
// ============================================================

model WhatsAppLog {
  id          String    @id @default(cuid())
  to          String
  message     String    @db.Text
  templateKey String?
  status      String    @default("pending")
  provider    String    @default("twilio")
  externalId  String?
  userId      String?
  requestId   String?
  quoteId     String?
  bookingId   String?
  error       String?   @db.Text
  sentAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([to])
  @@index([status])
  @@index([userId])
  @@index([requestId])
}

// ------------------------------------------------
// AUDIT LOG MODEL
// ------------------------------------------------
model AuditLog {
  id        String   @id @default(cuid())
  adminId   String
  admin     User     @relation("audit_admin", fields: [adminId], references: [id])
  action    String
  entity    String
  entityId  String?
  changes   Json?
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([entity])
  @@index([createdAt])
}

// ------------------------------------------------
// NOTIFICATION MODEL
// ------------------------------------------------
model Notification {
  id String @id @default(cuid())

  userId   String
  user     User    @relation(fields: [userId], references: [id])
  title    String
  message  String  @db.Text
  isRead   Boolean @default(false)
  type     String
  metadata Json?

  bookingId String?
  booking   VideoBooking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  requestId String?
  request   ProductRequest? @relation(fields: [requestId], references: [id], onDelete: Cascade)

  quoteId String?
  quote   Quote?  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  shipmentId String?
  shipment   Shipment? @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
}

// ------------------------------------------------
// CHAT SESSION MODEL
// ------------------------------------------------
model ChatSession {
  id        String        @id @default(cuid())
  userId    String?
  user      User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  startedAt DateTime      @default(now())
  endedAt   DateTime?
  messages  ChatMessage[]

  @@index([userId])
  @@index([startedAt])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String
  content   String      @db.Text
  createdAt DateTime    @default(now())

  @@index([sessionId])
}

// ============================================================
// GUEST CLIENTS  (clients registered by admin without an account)
// ============================================================
model GuestClient {
  id String @id @default(cuid())

  fullName      String
  email         String?
  phone         String?
  whatsappPhone String?
  company       String?
  country       String?
  notes         String? @db.Text

  isDeleted Boolean @default(false)

  createdById String
  createdBy   User   @relation("AdminCreatedGuestClients", fields: [createdById], references: [id])

  shipments Shipment[]
  invoices  Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([phone])
  @@index([createdById])
  @@index([isDeleted])
}

// ============================================================
// INTEGRATION SETTINGS  (admin-editable API keys / tokens)
// e.g. provider="17TRACK", key="API_KEY"  → used instead of .env
// ============================================================
model IntegrationSetting {
  id String @id @default(cuid())

  provider String // "17TRACK" | "SHIP24" | "AFTERSHIP" | "WHATSAPP" | ...
  key      String // "API_KEY" | "WEBHOOK_SECRET" | "ENABLED" | ...
  value    String @db.Text
  isSecret Boolean @default(true)

  updatedById String?
  updatedBy   User?   @relation(fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, key])
  @@index([provider])
}

// ============================================================
// SHIPMENTS  (core shipping + real-time tracking record)
// ============================================================
model Shipment {
  id           String @id @default(cuid())
  trackingCode String @unique // public-facing short code, e.g. "JHZ-7K3P9Q2A" — used for barcode + public tracking page

  // ── Client (registered user OR guest client) ──────────
  clientId String?
  client   User?   @relation("ClientShipments", fields: [clientId], references: [id], onDelete: SetNull)

  guestClientId String?
  guestClient   GuestClient? @relation(fields: [guestClientId], references: [id], onDelete: SetNull)

  // ── Optional links back into the sourcing flow ────────
  requestId String?
  request   ProductRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)

  quoteId String?
  quote   Quote?  @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  // ── Product info ───────────────────────────────────────
  productDescription String  @db.Text
  productLink         String?
  quantity            Int?    @default(1)

  // ── Route & method ─────────────────────────────────────
  originCountry      String
  destinationCountry String
  freightType        FreightType @default(SEA)
  carrierName        String? // e.g. "DHL", "China Post", "Aramex", "Local Forwarder"

  // ── Tracking ────────────────────────────────────────────
  carrierTrackingNumber String? // real tracking number with the carrier (if any)
  trackingSource         TrackingSource @default(MANUAL)
  providerCarrierCode    String? // carrier code returned by the tracking provider (e.g. 17TRACK carrier id)
  autoSyncEnabled        Boolean        @default(true)
  lastSyncedAt           DateTime?
  lastSyncError          String?        @db.Text

  // ── Weight / volume ─────────────────────────────────────
  weightKg Decimal? @db.Decimal(10, 3)
  volumeCbm Decimal? @db.Decimal(10, 4)

  // ── Costs ────────────────────────────────────────────────
  productCost   Decimal @default(0) @db.Decimal(12, 2)
  shippingCost  Decimal @default(0) @db.Decimal(12, 2)
  customsFees   Decimal @default(0) @db.Decimal(12, 2)
  otherFees     Decimal @default(0) @db.Decimal(12, 2)
  currency      String  @default("USD")

  // ── Status & ETA ─────────────────────────────────────────
  status            ShipmentStatus @default(BOOKED)
  estimatedDelivery DateTime?
  actualDelivery    DateTime?

  isDeleted Boolean @default(false)

  createdById String
  createdBy   User   @relation("AdminCreatedShipments", fields: [createdById], references: [id])

  images        ShipmentImage[]
  events        ShipmentEvent[]
  invoices      Invoice[]
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([guestClientId])
  @@index([requestId])
  @@index([quoteId])
  @@index([status])
  @@index([trackingCode])
  @@index([carrierTrackingNumber])
  @@index([isDeleted])
  @@index([createdAt])
}

model ShipmentImage {
  id         String   @id @default(cuid())
  shipmentId String
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  url       String
  altText   String?
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([shipmentId, sortOrder])
}

model ShipmentEvent {
  id         String   @id @default(cuid())
  shipmentId String
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  status      ShipmentStatus
  title       String
  titleAr     String?
  description String?        @db.Text
  descriptionAr String?      @db.Text
  location    String?

  occurredAt DateTime
  source     EventSource @default(MANUAL)
  rawPayload Json?

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([shipmentId, occurredAt])
  @@index([status])
}

// ============================================================
// INVOICES
// ============================================================
model Invoice {
  id            String @id @default(cuid())
  invoiceNumber String @unique // e.g. "INV-2026-000123"

  shipmentId String?
  shipment   Shipment? @relation(fields: [shipmentId], references: [id], onDelete: SetNull)

  clientId String?
  client   User?   @relation("ClientInvoices", fields: [clientId], references: [id], onDelete: SetNull)

  guestClientId String?
  guestClient   GuestClient? @relation(fields: [guestClientId], references: [id], onDelete: SetNull)

  requestId String?
  request   ProductRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)

  quoteId String?
  quote   Quote?  @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  items InvoiceItem[]

  subtotal    Decimal @default(0) @db.Decimal(12, 2)
  taxAmount   Decimal @default(0) @db.Decimal(12, 2)
  discount    Decimal @default(0) @db.Decimal(12, 2)
  totalAmount Decimal @default(0) @db.Decimal(12, 2)
  currency    String  @default("USD")

  status  InvoiceStatus @default(DRAFT)
  dueDate DateTime?
  paidAt  DateTime?
  notes   String?       @db.Text
  lang    String        @default("en") // "en" or "ar"

  pdfUrl         String?
  emailSentAt    DateTime?
  emailError     String?   @db.Text
  whatsappSentAt DateTime?

  isDeleted Boolean @default(false)

  createdById String
  createdBy   User   @relation("AdminCreatedInvoices", fields: [createdById], references: [id])

  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shipmentId])
  @@index([clientId])
  @@index([guestClientId])
  @@index([requestId])
  @@index([quoteId])
  @@index([status])
  @@index([isDeleted])
  @@index([createdAt])
}

model InvoiceItem {
  id        String  @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  description   String
  descriptionAr String?
  quantity      Int     @default(1)
  unitPrice     Decimal @db.Decimal(12, 2)
  lineTotal     Decimal @db.Decimal(12, 2)
  sortOrder     Int     @default(0)

  @@index([invoiceId])
}
