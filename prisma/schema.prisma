// prisma/schema.prisma

generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

// ------------------------------------------------
// ENUMS
// ------------------------------------------------

enum UserRole {
  ADMIN
  CLIENT
}

enum RequestStatus {
  SUBMITTED
  IN_REVIEW
  QUOTED
  APPROVED
  REJECTED
  IN_PRODUCTION
  SHIPPED
  COMPLETED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

enum BookingType {
  MARKET
  FACTORY
  CUSTOM
}

enum BookingStatus {
  REQUESTED
  PROPOSED // Admin proposed time
  CONFIRMED // Client accepted
  REJECTED // Client rejected
  RESCHEDULED
  COMPLETED
  CANCELED
  NO_SHOW
}

enum MeetingProvider {
  ZOOM
  GOOGLE_MEET
  WHATSAPP
  MICROSOFT_TEAMS
  CUSTOM
}

enum SubscriptionItemStatus {
  ACTIVE
  CANCELED
  UPCOMING
  ENDED
  ABANDONED
  INCOMPLETE
  PAST_DUE
}

enum PaymentAttemptType {
  CHECKOUT
  RECURRING
}

enum PaymentAttemptStatus {
  PENDING
  PAID
  FAILED
}

// ------------------------------------------------
// USER MODEL
// ------------------------------------------------
model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  fullName  String?
  role      UserRole @default(CLIENT)
  phone     String?
  avatarUrl String?

  isActive  Boolean @default(true)
  isDeleted Boolean @default(false)

  // -------------------------
  // Product Requests
  // -------------------------
  requests ProductRequest[]

  // -------------------------
  // Quotes
  // -------------------------
  quotesCreated Quote[] @relation("AdminQuotes")

  // -------------------------
  // Video Bookings
  // -------------------------
  clientBookings  VideoBooking[] @relation("ClientBookings")
  handledBookings VideoBooking[] @relation("AdminBookings")

  // -------------------------
  // Booking Status History
  // -------------------------
  bookingStatusChanges BookingStatusHistory[]

  // -------------------------
  // Request Status History
  // -------------------------
  requestStatusChanges RequestStatusHistory[]

  // -------------------------
  // Quote Status History
  // -------------------------
  quoteStatusChanges QuoteStatusHistory[]

  // -------------------------
  // Files
  // -------------------------
  uploadedFiles File[]

  // -------------------------
  // Notifications
  // -------------------------
  notifications Notification[]

  // -------------------------
  // Audit Logs
  // -------------------------
  adminAuditLogs AuditLog[] @relation("audit_admin")

  // -------------------------
  // Chat
  // -------------------------
  chatSessions ChatSession[]

  // -------------------------
  // Subscription (DO NOT TOUCH)
  // -------------------------
  subscription Subscription?

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  availabilitySlots AvailabilitySlot[]

  @@index([role])
  @@index([isDeleted])
}

// ------------------------------------------------
// SUBSCRIPTION MODEL (Top-level container)
// ------------------------------------------------
model Subscription {
  id                  String @id @default(cuid())
  clerkSubscriptionId String @unique

  // The payer: either a User or an Organization (but not both)
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Items belonging to this subscription (e.g., one for free plan, one for paid plan)
  items SubscriptionItem[]

  // Payment attempts related to this subscription (for checkout payments)
  paymentAttempts PaymentAttempt[]

  // Raw webhook payload for debugging
  lastSyncPayload Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId]) // Ensure only one subscription container per payer
  @@index([clerkSubscriptionId])
}

// ------------------------------------------------
// SUBSCRIPTION ITEM MODEL (Link between Payer and Plan)
// ------------------------------------------------
model SubscriptionItem {
  id          String @id @default(cuid())
  clerkItemId String @unique

  // Link to the top-level subscription container
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  // Link to the Plan
  planId String?
  plan   Plan?   @relation(fields: [planId], references: [id])

  // Status from Clerk events
  status SubscriptionItemStatus

  // Billing periods (from subscriptionItem.updated events)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?

  // Is this the default free plan? Clerk mentions default plan items have consistent ID.
  isDefaultPlan Boolean @default(false)

  // For trials (from subscriptionItem.freeTrialEnding event)
  trialEndsAt DateTime?

  // Payment attempts related to this item (for recurring charges)
  paymentAttempts PaymentAttempt[]

  // Raw webhook payload for debugging
  lastSyncPayload Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clerkItemId])
  @@index([status])
}

// ------------------------------------------------
// PAYMENT ATTEMPT MODEL (from Clerk billing)
// ------------------------------------------------
model PaymentAttempt {
  id                    String @id @default(cuid())
  clerkPaymentAttemptId String @unique

  // Type: checkout or recurring
  type PaymentAttemptType

  // Status: pending -> paid or failed
  status PaymentAttemptStatus

  // Link to the subscription item for recurring payments (optional for checkout)
  subscriptionItemId String?
  subscriptionItem   SubscriptionItem? @relation(fields: [subscriptionItemId], references: [id])

  // For checkout payments, link directly to the top-level subscription
  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])

  // Financial details (included in webhook)
  amount   Decimal? @db.Decimal(10, 2)
  currency String   @default("USD") // Non-nullable with default

  // Timestamp from the event
  occurredAt DateTime // when the attempt was created/updated in Clerk

  // Raw webhook payload
  payload Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clerkPaymentAttemptId])
  @@index([status])
}

// ------------------------------------------------
// PLAN MODEL (from Clerk billing)
// ------------------------------------------------
model Plan {
  id              String  @id @default(cuid())
  clerkPlanId     String  @unique // The ID from Clerk
  name            String
  amount          Decimal @db.Decimal(10, 2)
  currency        String  @default("USD")
  interval        String? // e.g., "month", "year"
  intervalCount   Int? // e.g., 1, 3, 12
  trialPeriodDays Int? // For free trials
  isDefault       Boolean @default(false) // If this is the default free plan

  // Relations
  subscriptionItems SubscriptionItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clerkPlanId])
}

// ------------------------------------------------
// VIDEO BOOKING (User Request)
// ------------------------------------------------
model VideoBooking {
  id String @id @default(cuid())

  // Client
  clientId String
  client   User   @relation("ClientBookings", fields: [clientId], references: [id])

  type            BookingType
  requestNotes    String?     @db.Text
  durationMinutes Int         @default(30)

  status BookingStatus @default(REQUESTED)

  // Admin who handled it
  handledById String?
  handledBy   User?   @relation("AdminBookings", fields: [handledById], references: [id])

  // Scheduling
  scheduledAt     DateTime?
  meetingProvider MeetingProvider?
  meetingLink     String?
  meetingPassword String?

  // Client confirmation
  clientConfirmedAt DateTime?

  // AI Data
  transcriptUrl String?
  aiSummary     String? @db.Text

  // Slot reference
  slotId String?           @unique
  slot   AvailabilitySlot? @relation(fields: [slotId], references: [id])

  // Enterprise
  isDeleted Boolean @default(false)

  statusHistory BookingStatusHistory[]
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([handledById])
  @@index([status])
  @@index([scheduledAt])
}

// ------------------------------------------------
// VIDEO BOOKING STATUS HISTORY
// ------------------------------------------------
model BookingStatusHistory {
  id String @id @default(cuid())

  bookingId String
  booking   VideoBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  oldStatus BookingStatus
  newStatus BookingStatus

  changedById String
  changedBy   User   @relation(fields: [changedById], references: [id])

  changedAt DateTime @default(now())

  @@index([bookingId])
}

// ------------------------------------------------
// AVAILABILITY SLOT (Created by Admin)
// ------------------------------------------------
model AvailabilitySlot {
  id String @id @default(cuid())

  startTime       DateTime
  endTime         DateTime
  durationMinutes Int

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  isBooked Boolean @default(false)
  isActive Boolean @default(true)

  booking VideoBooking?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startTime])
  @@index([createdById])
  @@index([isBooked])
}

// ------------------------------------------------
// PRODUCT REQUEST MODEL
// ------------------------------------------------
model ProductRequest {
  id String @id @default(cuid())

  clientId String
  client   User   @relation(fields: [clientId], references: [id])

  productLink     String?
  description     String? @db.Text
  quantity        Int
  shippingCountry String
  customNotes     String? @db.Text

  status   RequestStatus @default(SUBMITTED)
  priority Int           @default(0)

  acceptedQuoteId String? @unique
  acceptedQuote   Quote?  @relation("AcceptedQuote", fields: [acceptedQuoteId], references: [id])

  aiParsedData     Json?
  aiEstimatedPrice Decimal? @db.Decimal(10, 2)
  aiConfidence     Float?

  isDeleted Boolean @default(false)

  // Relations
  files         File[]
  quotes        Quote[]
  statusHistory RequestStatusHistory[]
  aiSuggestions AISuggestion[]
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([createdAt])
  @@index([isDeleted])
}

// ------------------------------------------------
// PRODUCT REQUEST STATUS HISTORY MODEL
// ------------------------------------------------
model RequestStatusHistory {
  id String @id @default(cuid())

  requestId String
  request   ProductRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  oldStatus RequestStatus
  newStatus RequestStatus

  changedById String
  changedBy   User   @relation(fields: [changedById], references: [id])

  changedAt DateTime @default(now())

  @@index([requestId])
}

// ------------------------------------------------
// QUOTE MODEL
// ------------------------------------------------
model Quote {
  id String @id @default(cuid())

  requestId String
  request   ProductRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("AdminQuotes", fields: [createdById], references: [id])

  price    Decimal @db.Decimal(12, 2)
  currency String  @default("USD")

  status QuoteStatus @default(DRAFT)

  validUntil DateTime?
  revision   Int       @default(1)

  adminNotes String? @db.Text

  isDeleted Boolean @default(false)

  acceptedFor ProductRequest? @relation("AcceptedQuote")

  // Relations 
  files         File[]
  statusHistory QuoteStatusHistory[]
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([requestId])
  @@index([createdById])
  @@index([status])
  @@index([isDeleted])
}

// ------------------------------------------------
// QUOTE STATUS HISTORY MODEL
// ------------------------------------------------
model QuoteStatusHistory {
  id String @id @default(cuid())

  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  oldStatus QuoteStatus
  newStatus QuoteStatus

  changedById String
  changedBy   User   @relation(fields: [changedById], references: [id])

  changedAt DateTime @default(now())

  @@index([quoteId])
}

// ------------------------------------------------
// FILE UPLOAD MODEL
// ------------------------------------------------
model File {
  id String @id @default(cuid())

  url      String
  fileType String
  fileName String?
  fileSize Int?

  requestId String?
  quoteId   String?

  request ProductRequest? @relation(fields: [requestId], references: [id], onDelete: Cascade)
  quote   Quote?          @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  uploadedById String?
  uploadedBy   User?   @relation(fields: [uploadedById], references: [id])

  createdAt DateTime @default(now())

  @@index([requestId])
  @@index([quoteId])
}

// ------------------------------------------------
// AI SUGGESTION MODEL
// ------------------------------------------------
model AISuggestion {
  id String @id @default(cuid())

  requestId String
  request   ProductRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  estimatedPrice Decimal @db.Decimal(10, 2)
  currency       String  @default("USD")
  confidence     Float?

  suggestedSupplierIds Json?

  createdAt DateTime @default(now())

  @@index([requestId])
}

// ------------------------------------------------
// AUDIT LOG MODEL (admin actions)
// ------------------------------------------------
model AuditLog {
  id        String   @id @default(cuid())
  adminId   String
  admin     User     @relation("audit_admin", fields: [adminId], references: [id])
  action    String // e.g., "UPDATE_REQUEST", "DELETE_QUOTE"
  entity    String // e.g., "ProductRequest", "Quote"
  entityId  String? // ID of the affected record
  changes   Json? // structured diff of before/after
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([entity])
  @@index([createdAt])
}

// ------------------------------------------------
// NOTIFICATIONS  MODEL
// ------------------------------------------------
model Notification {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  title   String
  message String @db.Text

  isRead Boolean @default(false)
  type   String

  metadata Json?
  // Relations

  bookingId String?
  booking   VideoBooking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  requestId String?
  request   ProductRequest? @relation(fields: [requestId], references: [id], onDelete: Cascade)

  quoteId String?
  quote   Quote?  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
}

// ------------------------------------------------
// CHAT SESSION MODEL (for AI chatbot / support chat)
// ------------------------------------------------
model ChatSession {
  id        String    @id @default(cuid())
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  startedAt DateTime  @default(now())
  endedAt   DateTime?

  messages ChatMessage[]

  @@index([userId])
  @@index([startedAt])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String // "user" or "assistant"
  content   String      @db.Text
  createdAt DateTime    @default(now())

  @@index([sessionId])
}
